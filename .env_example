# Google Calendar API Credentials
# The path to your downloaded OAuth 2.0 client ID JSON file.
# We see you have one in the directory, you can rename it to credentials.json or point this variable to it.
CREDENTIALS_FILE=client_secret_xxxxx.apps.googleusercontent.com.json

# Ollama Model selection
# Defaulting to the model listed in your ollama setup
OLLAMA_MODEL=qwen3-coder:30b
OLLAMA_NUM_CTX=32768

# Your preferred timezone for the agent to know when creating events
SERVER_TIMEZONE=America/Los_Angeles

# Feature Flags
ENABLE_WEB_SCRAPING=false
ENABLE_DEEP_RESEARCH=false

# Discord Bot Token
# Get this from https://discord.com/developers/applications
DISCORD_TOKEN=your_bot_token_here

# SearXNG Search Tool
SEARXNG_URL=http://localhost:8080

# Firecrawl Web Scraping Tool
FIRECRAWL_URL=http://localhost:3002
# FIRECRAWL_API_KEY=your_api_key_here (if using cloud version)
